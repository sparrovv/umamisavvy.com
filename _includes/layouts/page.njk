---
layout: base.njk
---

<!-- Page Header -->
<header class="intro-header" style="background-image: url('{{ header-img if header-img else metadata.headerImage }}')">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-lg-offset-2 col-md-10 col-md-offset-1">
                <div class="site-heading site-heading-big">
                    <h1>{{ title }}</h1>
                    <hr class="small">
                    <span class="subheading">{{ description }}</span>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Main Content -->
<div class="container">
    <div class="row">
        <div class="col-lg-8 col-lg-offset-2 col-md-10 col-md-offset-1">
            {{ content | safe }}
        </div>
    </div>
</div>

<hr> 